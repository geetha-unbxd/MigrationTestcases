# Copy to .env and configure for Unbxd Console login (Node export / optional Java Google flow)
GOOGLE_EMAIL=your_google_email@gmail.com
GOOGLE_PASSWORD=your_google_password
TOTP_SECRET=your_totp_secret_from_authenticator_app

# Login page base (no trailing slash). Default in code: https://console.unbxd.io
CONSOLE_LOGIN_BASE_URL=https://console.unbxd.io

# Regional target URL after OAuth callback (can also be passed by Java env)
CONSOLE_TARGET_URL=https://console-uk.unbxd.io

# Optional: set false to see browser while debugging
HEADLESS=true

# When Google shows CAPTCHA / bot check, wait this long (ms) for manual solve — default 120000 (2 min)
# CAPTCHA_MANUAL_WAIT_MS=120000

# Java/Selenium: when GOOGLE_EMAIL/GOOGLE_PASSWORD are set (unset flag = auto), only Google login runs—no YAML form fallback. Set false for form login only.
# USE_CONSOLE_GOOGLE_LOGIN=false

# If the JVM working directory is not the repo root, set in shell or IDE (or -Dconsole.login.dir=...), not only here:
# export CONSOLE_LOGIN_DIR="/path/to/Migration script/console-login"
